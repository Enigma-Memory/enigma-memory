{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.enigma.ai/trust-card-v1.schema.json",
  "title": "Enigma Trust Card v1",
  "type": "object",
  "required": [
    "schema",
    "trust_card_id",
    "generated_at",
    "subject",
    "posture",
    "claim_ids",
    "claims",
    "evidence_refs",
    "roots",
    "boundary"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "enigma.trust_card.v1" },
    "trust_card_id": { "$ref": "#/$defs/publicId" },
    "generated_at": { "type": "string", "format": "date-time" },
    "subject": { "$ref": "#/$defs/trustSubject" },
    "posture": { "type": "string", "enum": ["unknown", "reviewed", "trusted", "quarantined", "blocked"] },
    "claim_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/claimId" },
      "uniqueItems": true
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/claimSummary" }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/publicRef" },
      "uniqueItems": true
    },
    "roots": { "$ref": "#/$defs/trustRoots" },
    "boundary": { "$ref": "#/$defs/boundaryBooleans" }
  },
  "$defs": {
    "sha256Digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "publicId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._:-]{7,127}$" },
    "publicRef": { "type": "string", "pattern": "^ref:[A-Za-z0-9][A-Za-z0-9._~:@#?=&%+-]{0,255}$" },
    "claimId": { "type": "string", "pattern": "^claim:[a-z0-9][a-z0-9._:-]{2,127}$" },
    "schemaId": { "type": "string", "pattern": "^enigma\\.[a-z0-9_]+\\.v1$" },
    "trustSubject": {
      "type": "object",
      "required": ["subject_type", "subject_id", "subject_ref", "subject_hash"],
      "additionalProperties": false,
      "properties": {
        "subject_type": { "type": "string", "enum": ["connector", "package"] },
        "subject_id": { "$ref": "#/$defs/publicId" },
        "subject_ref": { "$ref": "#/$defs/publicRef" },
        "subject_hash": { "$ref": "#/$defs/sha256Digest" }
      }
    },
    "claimSummary": {
      "type": "object",
      "required": ["claim_id", "claim_type", "status", "evidence_refs"],
      "additionalProperties": false,
      "properties": {
        "claim_id": { "$ref": "#/$defs/claimId" },
        "claim_type": { "$ref": "#/$defs/schemaId" },
        "status": { "type": "string", "enum": ["unverified", "supported", "rejected", "withdrawn"] },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/publicRef" },
          "uniqueItems": true
        }
      }
    },
    "trustRoots": {
      "type": "object",
      "required": ["claim_root", "evidence_root", "receipt_chain_root"],
      "additionalProperties": false,
      "properties": {
        "claim_root": { "$ref": "#/$defs/sha256Digest" },
        "evidence_root": { "$ref": "#/$defs/sha256Digest" },
        "receipt_chain_root": { "$ref": "#/$defs/sha256Digest" }
      }
    },
    "boundaryBooleans": {
      "type": "object",
      "required": [
        "public_payload_only",
        "raw_memory_included",
        "raw_prompt_included",
        "raw_transcript_included",
        "raw_embedding_included",
        "private_key_included",
        "credential_included",
        "local_path_included",
        "provider_deletion_claim",
        "model_forgetting_claim",
        "hosted_saas_ready_claim"
      ],
      "additionalProperties": false,
      "properties": {
        "public_payload_only": { "const": true },
        "raw_memory_included": { "const": false },
        "raw_prompt_included": { "const": false },
        "raw_transcript_included": { "const": false },
        "raw_embedding_included": { "const": false },
        "private_key_included": { "const": false },
        "credential_included": { "const": false },
        "local_path_included": { "const": false },
        "provider_deletion_claim": { "const": false },
        "model_forgetting_claim": { "const": false },
        "hosted_saas_ready_claim": { "const": false }
      }
    }
  }
}
