{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.enigma.ai/memory-weather-report-v1.schema.json",
  "title": "Enigma Memory Weather Report v1",
  "type": "object",
  "required": [
    "schema",
    "status",
    "generated_at",
    "tiles",
    "issue_codes",
    "next_action",
    "evidence_refs",
    "public_payload_only",
    "memory_payload_absent",
    "prompt_payload_absent",
    "transcript_payload_absent",
    "embedding_payload_absent",
    "provider_output_absent",
    "secret_material_absent",
    "device_path_absent",
    "account_identifier_absent",
    "customer_identifier_absent",
    "evidence_refs_only",
    "provider_deletion_claim",
    "model_forgetting_claim",
    "provider_native_memory_control_claim",
    "compliance_certification_claim"
  ],
  "allOf": [
    {
      "if": {
        "properties": { "status": { "const": "sunny" } },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "issue_codes": { "maxItems": 0 },
          "next_action": { "const": "none" }
        }
      }
    },
    {
      "if": {
        "properties": { "status": { "enum": ["needs_attention", "storm_warning"] } },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "issue_codes": { "minItems": 1 }
        }
      }
    }
  ],
  "additionalProperties": false,
  "properties": {
    "schema": { "const": "enigma.memory_weather_report.v1" },
    "status": { "type": "string", "enum": ["sunny", "needs_attention", "storm_warning"] },
    "generated_at": { "type": "string", "format": "date-time" },
    "tiles": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/weatherTile" }
    },
    "issue_codes": {
      "type": "array",
      "items": { "$ref": "#/$defs/issueCode" },
      "uniqueItems": true
    },
    "next_action": { "$ref": "#/$defs/nextAction" },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/publicRef" },
      "uniqueItems": true
    },
    "public_payload_only": { "const": true },
    "memory_payload_absent": { "const": true },
    "prompt_payload_absent": { "const": true },
    "transcript_payload_absent": { "const": true },
    "embedding_payload_absent": { "const": true },
    "provider_output_absent": { "const": true },
    "secret_material_absent": { "const": true },
    "device_path_absent": { "const": true },
    "account_identifier_absent": { "const": true },
    "customer_identifier_absent": { "const": true },
    "evidence_refs_only": { "const": true },
    "provider_deletion_claim": { "const": false },
    "model_forgetting_claim": { "const": false },
    "provider_native_memory_control_claim": { "const": false },
    "compliance_certification_claim": { "const": false }
  },
  "$defs": {
    "publicRef": {
      "type": "string",
      "pattern": "^ref:[A-Za-z0-9][A-Za-z0-9._~:@#?=&%+-]{0,255}$"
    },
    "weatherTile": {
      "type": "object",
      "required": ["tile_ref", "status", "metric", "count", "evidence_refs"],
      "additionalProperties": false,
      "properties": {
        "tile_ref": { "$ref": "#/$defs/publicRef" },
        "status": { "type": "string", "enum": ["sunny", "needs_attention", "storm_warning"] },
        "metric": { "$ref": "#/$defs/tileMetric" },
        "count": { "type": "integer", "minimum": 0 },
        "evidence_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/publicRef" },
          "uniqueItems": true
        }
      }
    },
    "tileMetric": {
      "type": "string",
      "enum": [
        "active_grants",
        "expiring_grants",
        "recent_vetoes",
        "open_private_bubbles",
        "tombstone_pressure",
        "sensitive_candidates",
        "receipt_coverage"
      ]
    },
    "issueCode": {
      "type": "string",
      "enum": [
        "grant_expiring",
        "grant_missing",
        "policy_attention_needed",
        "veto_rate_elevated",
        "private_bubble_open",
        "receipt_gap",
        "tombstone_pressure",
        "sensitive_candidate_pressure"
      ]
    },
    "nextAction": {
      "type": "string",
      "enum": [
        "none",
        "review_grants",
        "review_policy",
        "ask_for_consent",
        "close_private_bubbles",
        "inspect_receipts"
      ]
    }
  }
}
